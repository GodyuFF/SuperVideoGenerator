# SuperVideoGenerator LLM（ReAct XML）
# 默认 DeepSeek；也可通过 SVG_LLM_PROVIDER 切换服务商

# 通用 Key（优先于服务商专用变量时可设此项）
# SVG_LLM_API_KEY=

# DeepSeek（默认）
SVG_LLM_PROVIDER=deepseek
# SVG_LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI
# SVG_LLM_PROVIDER=openai
# SVG_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Moonshot Kimi
# SVG_LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=

# 智谱
# SVG_LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=

# 通义千问
# SVG_LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=

# OpenRouter（聚合多模型）
# SVG_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=

# 无 Key 时自动使用规则回退（测试/本地 Mock）
# SVG_LLM_USE_LLM_REACT=false

# 开发态持久化 MemoryStore（避免 uvicorn reload 丢会话，默认开启）
# SVG_PERSIST_STORE=1

# 是否使用系统代理连接 LLM（默认 false，避免代理导致 ConnectError）
# SVG_LLM_TRUST_ENV=false

# Token 预算（输入侧 gate + 输出 completion 上限）
# SVG_LLM_MAX_TOKENS=8192
# SVG_LLM_CONTEXT_WINDOW_TOKENS=1048576
# SVG_LLM_HISTORY_KEEP_MESSAGES=10

# Agnes AI 生图（默认 provider=agnes，OpenAI 兼容）
# SVG_IMAGE_GEN_API_KEY=your_agnes_api_key
# SVG_IMAGE_GEN_MODEL=agnes-image-2.1-flash
# SVG_IMAGE_GEN_BASE_URL=https://apihub.agnes-ai.com/v1
# SVG_IMAGE_GEN_DEFAULT_SIZE=1024x768
# AGNES_API_KEY=your_agnes_api_key

# 本地 Stable Diffusion WebUI（provider=local_sd）
# SVG_IMAGE_GEN_PROVIDER=local_sd
# SVG_IMAGE_GEN_SD_BASE_URL=http://127.0.0.1:7860
# SVG_IMAGE_GEN_SD_STEPS=20
# SVG_IMAGE_GEN_SD_CFG_SCALE=7.0
# SVG_IMAGE_GEN_SD_SAMPLER=Euler a
# SVG_IMAGE_GEN_SD_NEGATIVE_PROMPT=low quality, blurry

# 阿里云百炼 DashScope 生图（provider=bailian）
# SVG_IMAGE_GEN_PROVIDER=bailian
# SVG_IMAGE_GEN_API_KEY=your_dashscope_api_key
# SVG_IMAGE_GEN_BAILIAN_WORKSPACE_ID=your_workspace_id
# SVG_IMAGE_GEN_BAILIAN_TXT2IMG_MODEL=wanx2.5-t2i-turbo
# SVG_IMAGE_GEN_BAILIAN_IMG2IMG_MODEL=qwen-image-2.0-pro
# DASHSCOPE_API_KEY=your_dashscope_api_key

# 火山方舟 SeedDream 生图 / SeedDance 生视频
# ARK_API_KEY=your_volcengine_ark_api_key
# SVG_IMAGE_GEN_PROVIDER=volcengine
# SVG_IMAGE_GEN_MODEL=doubao-seedream-5-0-pro
# 控制台推理接入点 ID 常带日期后缀，例如 doubao-seedream-5-0-pro-260628（以其为准）
# SVG_IMAGE_GEN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# SVG_VIDEO_GEN_ENABLED=true
# SVG_VIDEO_GEN_PROVIDER=volcengine
# SVG_VIDEO_GEN_MODEL=doubao-seedance-2-0
# SVG_VIDEO_GEN_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# AI 视频（Agnes 或火山方舟）
# SVG_VIDEO_GEN_API_KEY=
# SVG_VIDEO_GEN_MODEL=agnes-video-v2.0
# Agnes Free：状态查询轮询 15s；创建约 1 次/分钟（默认间隔 60s）；并发 1；遇 429 自动退避重试
# SVG_VIDEO_GEN_POLL_INTERVAL_SEC=15
# SVG_VIDEO_GEN_CREATE_MIN_INTERVAL_SEC=60
# SVG_VIDEO_GEN_CREATE_MAX_ATTEMPTS=4
# SVG_VIDEO_GEN_MAX_CONCURRENCY=1
# SVG_VIDEO_GEN_TIMEOUT_SEC=600

# A2UI 确认默认超时（秒）。留空 / 0 / none = 无限等待用户操作（推荐）
# 设为正数时启用超时，超时后推送 a2ui_confirmation_expired
# SVG_A2UI_DEFAULT_TIMEOUT_SEC=

# TTS（预留）
# SVG_TTS_API_KEY=
# SVG_TTS_MODEL=tts-1

# RAG 共享资产复用 Embedding（也可在「AI 配置 → Embedding / RAG」页填写）
# SVG_RAG_EMBEDDING_API_KEY=   # 优先于 OPENAI_API_KEY；未配置时按名称匹配复用
# SVG_RAG_EMBEDDING_BASE_URL=https://api.openai.com/v1
# SVG_RAG_EMBEDDING_MODEL=text-embedding-3-small

# WhisperX 字幕对齐/转写（缺 TTS cue 时；仅 NVIDIA CUDA）
# SVG_WHISPERX_LANGUAGE=zh
# SVG_WHISPERX_MODEL=base
# SVG_WHISPERX_ALIGN_MODEL=
