# SuperVideoGenerator LLM（ReAct XML）
# 默认 DeepSeek；也可通过 SVG_LLM_PROVIDER 切换服务商

# 通用 Key（优先于服务商专用变量时可设此项）
# SVG_LLM_API_KEY=

# DeepSeek（默认）
SVG_LLM_PROVIDER=deepseek
# SVG_LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI
# SVG_LLM_PROVIDER=openai
# SVG_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Moonshot Kimi
# SVG_LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=

# 智谱
# SVG_LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=

# 通义千问
# SVG_LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=

# OpenRouter（聚合多模型）
# SVG_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=

# 无 Key 时自动使用规则回退（测试/本地 Mock）
# SVG_LLM_USE_LLM_REACT=false

# 开发态持久化 MemoryStore（避免 uvicorn reload 丢会话，默认开启）
# SVG_PERSIST_STORE=1

# 是否使用系统代理连接 LLM（默认 false，避免代理导致 ConnectError）
# SVG_LLM_TRUST_ENV=false

# Token 预算（输入侧 gate + 输出 completion 上限）
# SVG_LLM_MAX_TOKENS=8192
# SVG_LLM_CONTEXT_WINDOW_TOKENS=1048576
# SVG_LLM_HISTORY_KEEP_MESSAGES=10

# Agnes AI 生图（默认 provider=agnes，OpenAI 兼容）
# SVG_IMAGE_GEN_API_KEY=your_agnes_api_key
# SVG_IMAGE_GEN_MODEL=agnes-image-2.0-flash
# SVG_IMAGE_GEN_BASE_URL=https://apihub.agnes-ai.com/v1
# SVG_IMAGE_GEN_DEFAULT_SIZE=1024x768
# AGNES_API_KEY=your_agnes_api_key

# AI 视频（预留）
# SVG_VIDEO_GEN_API_KEY=
# SVG_VIDEO_GEN_MODEL=agnes-video-v2.0

# TTS（预留）
# SVG_TTS_API_KEY=
# SVG_TTS_MODEL=tts-1
