# SuperVideoGenerator LLM（ReAct XML）
# 默认 DeepSeek；也可通过 SVG_LLM_PROVIDER 切换服务商

# 通用 Key（优先于服务商专用变量时可设此项）
# SVG_LLM_API_KEY=

# DeepSeek（默认）
SVG_LLM_PROVIDER=deepseek
# SVG_LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your_deepseek_api_key

# OpenAI
# SVG_LLM_PROVIDER=openai
# SVG_LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# Moonshot Kimi
# SVG_LLM_PROVIDER=moonshot
# MOONSHOT_API_KEY=

# 智谱
# SVG_LLM_PROVIDER=zhipu
# ZHIPU_API_KEY=

# 通义千问
# SVG_LLM_PROVIDER=qwen
# DASHSCOPE_API_KEY=

# OpenRouter（聚合多模型）
# SVG_LLM_PROVIDER=openrouter
# OPENROUTER_API_KEY=

# 无 Key 时自动使用规则回退（测试/本地 Mock）
# SVG_LLM_USE_LLM_REACT=false

# 开发态持久化 MemoryStore（避免 uvicorn reload 丢会话，默认开启）
# SVG_PERSIST_STORE=1

# 是否使用系统代理连接 LLM（默认 false，避免代理导致 ConnectError）
# SVG_LLM_TRUST_ENV=false
