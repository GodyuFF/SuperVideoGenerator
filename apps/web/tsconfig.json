{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@opencut/*": ["./src/editor/opencut/*"],
      "next/link": ["./src/editor/opencut/shims/next-link.tsx"],
      "next/image": ["./src/editor/opencut/shims/next-image.tsx"],
      "next/navigation": ["./src/editor/opencut/shims/next-navigation.ts"]
    }
  },
  "exclude": ["src/editor/opencut/**"]
}
